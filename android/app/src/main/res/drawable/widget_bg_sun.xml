<?xml version="1.0" encoding="utf-8"?>
<!-- Sunlight board: near-white ground so signal colours read at 7:1 in direct
     sun (FR-5.3). Selected in code, not by qualifier — sunlight is a choice. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/rc_sun_board" />
    <stroke android:width="1dp" android:color="@color/rc_sun_ink3" />
    <corners android:radius="20dp" />
</shape>

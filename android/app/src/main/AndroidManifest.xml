<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Notifications + full-screen arrival alarm (FR-7.3, backlog 4.8). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- Offline banner reads connectivity (FR-9.1, backlog 4.9). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- "Trains near me" resolves the nearest station; coarse is enough and the
         permission is requested in context on tap (FR-5.2). -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Package-visibility (API 30+): without this, resolveActivity() cannot see
         the system speech recognizer and voice search silently no-ops (FR-1.4). -->
    <queries>
        <intent>
            <action android:name="android.speech.action.RECOGNIZE_SPEECH" />
        </intent>
    </queries>

    <application
        android:name=".RailcastApplication"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Railcast">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- FCM entry point (FR-7.2/7.3). Inert until google-services.json is
             bundled — Firebase never starts it without config. -->
        <service
            android:name=".feature.alerts.RailcastMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Full-screen arrival alarm; shows over the lock screen (FR-7.3). -->
        <activity
            android:name=".feature.alerts.AlarmActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Railcast" />

        <!-- Ambient journey widget (docs/design/direction-study.md): the answer
             on the home screen, so the common case needs no launch at all. -->
        <receiver
            android:name=".feature.ambient.JourneyWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_journey_info" />
        </receiver>

        <!-- Mute action on the live journey notification (FR-7.4). Not exported:
             only our own PendingIntent triggers it. -->
        <receiver
            android:name=".feature.ambient.LiveJourneyMuteReceiver"
            android:exported="false" />
    </application>

</manifest>

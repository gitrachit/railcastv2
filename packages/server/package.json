{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "tsx src/index.ts",
    "migrate": "tsx --env-file-if-exists=.env src/db/run-migrate.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@railcast/shared": "workspace:*",
    "bullmq": "^5.79.3",
    "fastify": "^5.3.2",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/pg": "^8.20.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
